# NVIDIA Build hosted endpoint. Never commit the real .env file.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Choose models enabled in your NVIDIA Build account. These defaults are editable in the app.
NVIDIA_VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NVIDIA_WRITER_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Naver Login is optional and identifies the app user only. It does not publish a blog post.
# Create an application in NAVER Developers and register this exact callback URL.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://127.0.0.1:8765/callback
